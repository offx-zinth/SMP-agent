# LLM Provider (anthropic | openai | gemini)
NEMOTRON_LLM_PROVIDER=gemini

# API Keys (set the one matching your provider)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIzaSyCMIWD9RRcQk5gBlKxA1b6dnhj0i2wrjqU

# Model override (optional — defaults: claude-sonnet-4-20250514, gpt-4o, gemini-2.5-flash)
NEMOTRON_MODEL=gemma-4-31b-it
# SMP Server
SMP_URL=http://localhost:8420

# Agent settings
NEMOTRON_MAX_ITERATIONS=1000
NEMOTRON_AUTO_INDEX=true
